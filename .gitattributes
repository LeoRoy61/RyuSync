# RyuSync — Git line ending normalization
# Ensure consistent line endings across Windows/Linux/macOS contributors

* text=auto

# Python source
*.py text eol=lf

# Markdown
*.md text eol=lf

# YAML/Config
*.yml text eol=lf
*.yaml text eol=lf

# Text files
*.txt text eol=lf
*.cfg text eol=lf

# Binary files — never convert
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.zip binary
*.pyc binary
